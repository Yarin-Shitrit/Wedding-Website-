# PostgreSQL connection string (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://wedding:wedding@localhost:5432/wedding?schema=public"

# Admin login password (change this before deploying)
ADMIN_PASSWORD="change-me-before-deploy"

# 32+ char random secret for signing session JWTs. Generate with:
#   openssl rand -base64 32
SESSION_SECRET="replace-with-32-plus-char-random-string"

# Wedding date (ISO-8601) — drives the countdown on the public page
NEXT_PUBLIC_WEDDING_DATE="2026-09-15T19:00:00+03:00"

# Couple names for the header / title
NEXT_PUBLIC_BRIDE_NAME="כלה"
NEXT_PUBLIC_GROOM_NAME="חתן"
