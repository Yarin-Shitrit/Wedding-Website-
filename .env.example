# Copy to .env and fill in values
DATABASE_URL="file:./dev.db"

# Admin auth (set a strong secret in production)
AUTH_SECRET="change-me-to-a-long-random-string"
ADMIN_EMAIL="couple@example.com"
ADMIN_PASSWORD="change-me"

# Wedding details shown on the site
NEXT_PUBLIC_BRIDE_NAME="Amit"
NEXT_PUBLIC_GROOM_NAME="Ben"
NEXT_PUBLIC_WEDDING_DATE="2026-09-04T19:00:00+03:00"
NEXT_PUBLIC_VENUE_NAME="The Garden"
NEXT_PUBLIC_VENUE_ADDRESS="123 Main St, Tel Aviv"
NEXT_PUBLIC_VENUE_MAP_URL="https://maps.google.com/?q=Tel+Aviv"

# SnapFinder integration
# Public — base URL of the running SnapFinder backend (used by the SDK script tag)
NEXT_PUBLIC_SNAPFINDER_API_URL="http://localhost:8000"
# Server-only — UUID of the event row in SnapFinder (response from POST /events)
SNAPFINDER_EVENT_ID="CHANGE_ME_event_id"
# Server-only — must match the SnapFinder backend's JWT_SECRET exactly
SNAPFINDER_JWT_SECRET="CHANGE_ME_jwt_secret"
# Lifetime in seconds of the per-guest event JWT minted by /photos
SNAPFINDER_EVENT_TOKEN_TTL="3600"
