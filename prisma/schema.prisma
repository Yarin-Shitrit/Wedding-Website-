generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// SQLite does not support Prisma enums; both fields are validated at the
// application layer (zod) and constrained to the values below.
//   RsvpStatus: PENDING | ATTENDING | DECLINED | MAYBE
//   Side:       BRIDE | GROOM | SHARED

model Guest {
  id              String     @id @default(cuid())
  firstName       String
  lastName        String?
  phone           String?    @unique
  email           String?
  side            String     @default("SHARED")
  group           String?
  seatsInvited    Int        @default(1)
  seatsConfirmed  Int        @default(0)
  status          String     @default("PENDING")
  dietary         String?
  notes           String?
  rsvpToken       String     @unique @default(cuid())
  respondedAt     DateTime?
  tableId         String?
  table           Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
  @@index([tableId])
}

model Table {
  id        String  @id @default(cuid())
  name      String  @unique
  capacity  Int     @default(10)
  notes     String?
  guests    Guest[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id              String   @id @default("singleton")
  brideName       String   @default("Amit")
  groomName       String   @default("Ben")
  weddingDate     DateTime @default(now())
  venueName       String   @default("The Garden")
  venueAddress    String   @default("")
  venueMapUrl     String   @default("")
  parkingInfo     String   @default("")
  dressCode       String   @default("")
  welcomeMessage  String   @default("")

  // ─── design refactor additions ───
  storyTitle      String   @default("הסיפור שלנו")
  storyEyebrow    String   @default("פרק ראשון")
  storyBody       String   @default("")
  storyQuote      String   @default("")
  shuttleInfo     String   @default("")
  heroLayout      String   @default("centered") // "centered" | "split"
  palette         String   @default("terracotta")
  rsvpDeadline    String   @default("12.10")

  updatedAt       DateTime @updatedAt
}

model Moment {
  id        String   @id @default(cuid())
  chapter   String   @default("I")
  year      String
  title     String
  body      String
  imageUrl  String?
  imageAlt  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model GalleryItem {
  id        String   @id @default(cuid())
  src       String?
  alt       String
  ratio     String   @default("1/1")
  span      Int      @default(1)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model ScheduleItem {
  id        String   @id @default(cuid())
  time      String
  title     String
  body      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}
