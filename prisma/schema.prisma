generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RsvpStatus {
  PENDING
  ATTENDING
  DECLINED
  MAYBE
}

enum Side {
  BRIDE
  GROOM
  SHARED
}

model Guest {
  id              String     @id @default(cuid())
  firstName       String
  lastName        String?
  phone           String?    @unique
  email           String?
  side            Side       @default(SHARED)
  group           String?
  seatsInvited    Int        @default(1)
  seatsConfirmed  Int        @default(0)
  status          RsvpStatus @default(PENDING)
  dietary         String?
  notes           String?
  rsvpToken       String     @unique @default(cuid())
  respondedAt     DateTime?
  tableId         String?
  table           Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
  @@index([tableId])
}

model Table {
  id        String  @id @default(cuid())
  name      String  @unique
  capacity  Int     @default(10)
  notes     String?
  guests    Guest[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id              String   @id @default("singleton")
  brideName       String   @default("Amit")
  groomName       String   @default("Ben")
  weddingDate     DateTime @default(now())
  venueName       String   @default("The Garden")
  venueAddress    String   @default("")
  venueMapUrl     String   @default("")
  parkingInfo     String   @default("")
  dressCode       String   @default("")
  welcomeMessage  String   @default("")
  updatedAt       DateTime @updatedAt
}
